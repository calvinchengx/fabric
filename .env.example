# Copy to .env — never commit real secrets.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Optional (CLI `create-sql-connection` only; not used by workspace provisioning commands)
# Use this instead of `--sql-password` for SQL basic auth to avoid exposing secrets in shell history.
# FABRIC_SQL_CONNECTION_PASSWORD=
# Use this instead of `--sql-auth-client-secret` for SQL AAD SPN auth.
# This secret is for the target SQL connection auth, not `AZURE_CLIENT_SECRET` (provisioner app auth).
# FABRIC_SQL_AUTH_CLIENT_SECRET=

# Optional overrides (defaults match Fabric / Graph public endpoints)
# FABRIC_API_SCOPE=https://api.fabric.microsoft.com/.default
# GRAPH_API_SCOPE=https://graph.microsoft.com/.default
# FABRIC_API_BASE=https://api.fabric.microsoft.com/v1
# GRAPH_API_BASE=https://graph.microsoft.com/v1.0

# If true, verify each Entra group and assigned SPN exists via Graph (Group + Application.Read.All or broader)
# VALIDATE_GROUP_IDS_WITH_GRAPH=false

# Optional: POST JSON payload after successful provision
# INTEGRATION_WEBHOOK_URL=https://internal.example.com/hooks/fabric-provision

# Optional: append-only audit file (JSON lines)
# AUDIT_JSONL_PATH=./var/audit.jsonl
